<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Scale group carefully centered inside the 108x108 viewport (75% scale, centered) -->
    <group
        android:name="safe_zone_group"
        android:scaleX="0.75"
        android:scaleY="0.75"
        android:translateX="13.5"
        android:translateY="13.5">

        <!-- Outer Glowing Neon-Green Ring -->
        <path
            android:pathData="M 54,16 A 38,38 0 1,1 53.9,16 Z"
            android:strokeWidth="1.8"
            android:strokeColor="#FF00FF88"
            android:strokeLineCap="round" />

        <!-- Inner Accent Ring -->
        <path
            android:pathData="M 54,18 A 36,36 0 1,1 53.9,18 Z"
            android:strokeWidth="0.8"
            android:strokeColor="#8000FF88"
            android:strokeLineCap="round" />

        <!-- SHOPPING BAG (Highly details rounded modern vector) -->
        <!-- 1. Bag Handles -->
        <path
            android:pathData="M 44,42 C 44,32 64,32 64,42"
            android:strokeWidth="2.2"
            android:strokeColor="#FF00FF88"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <path
            android:pathData="M 46,42 C 46,35 62,35 62,42"
            android:strokeWidth="1.0"
            android:strokeColor="#FFFFFFFF"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <!-- 2. Main Bag Body -->
        <path
            android:pathData="M 40,43 L 68,43 C 71,43 72,45 71.5,48 L 66.5,70 C 66,73 63.5,75 60.5,75 L 47.5,75 C 44.5,75 42,73 41.5,70 L 36.5,48 C 36,45 37,43 40,43 Z"
            android:strokeWidth="2.2"
            android:strokeColor="#FF00FF88"
            android:strokeLineJoin="round"
            android:fillColor="#150a0c10" />

        <path
            android:pathData="M 41.5,45 L 66.5,45 L 62.5,73 L 45.5,73 Z"
            android:fillColor="#0c1219" />

        <!-- 3. Eco-Leaf Details inside the bag -->
        <path
            android:pathData="M 48,67 C 48,67 44,56 55,54 C 55,54 57,64 48,67 Z"
            android:strokeWidth="1.2"
            android:strokeColor="#FF00FF88"
            android:fillColor="#3000FF88" />

        <!-- 4. Glowing leaf arrow overlay -->
        <path
            android:pathData="M 48,67 Q 54,60 64,54"
            android:strokeWidth="1.8"
            android:strokeColor="#FF00FF88"
            android:strokeLineCap="round" />

        <path
            android:pathData="M 60,54 L 64,54 L 64,58"
            android:strokeWidth="1.8"
            android:strokeColor="#FF00FF88"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />

        <!-- SLEEK NEON STAR & BOTTOM HORIZONTAL STABILIZERS -->
        <group android:name="bottom_star_accent" android:translateY="3">
            <!-- Center Star -->
            <path
                android:pathData="M 54,78 L 55.5,81 L 59,81 L 56,83 L 57.5,86 L 54,84.2 L 50.5,86 L 52,83 L 49,81 L 52.5,81 Z"
                android:fillColor="#FFFFFFFF" />
            
            <!-- Left Wing Neon Line -->
            <path
                android:pathData="M 38,81 H 46"
                android:strokeWidth="1.2"
                android:strokeColor="#FF00FF88"
                android:strokeLineCap="round" />

            <!-- Right Wing Neon Line -->
            <path
                android:pathData="M 62,81 H 70"
                android:strokeWidth="1.2"
                android:strokeColor="#FF00FF88"
                android:strokeLineCap="round" />
        </group>

        <!-- Dynamic arch indicators in place of small unreadable text -->
        <path
            android:pathData="M 28,30 C 33,23 43,19 54,19 C 65,19 75,23 80,30"
            android:strokeWidth="0.8"
            android:strokeColor="#40FFFFFF"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <path
            android:pathData="M 32,84 C 38,88 46,90 54,90 C 62,90 70,88 76,84"
            android:strokeWidth="0.8"
            android:strokeColor="#40FFFFFF"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

    </group>

</vector>
