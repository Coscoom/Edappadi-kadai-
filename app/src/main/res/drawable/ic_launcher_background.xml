<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Deep slate black background matching the logo background -->
    <path
        android:pathData="M 0,0 L 108,0 L 108,108 L 0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:color="#0a0c0f" android:offset="0" />
                <item android:color="#0e1115" android:offset="0.5" />
                <item android:color="#14181f" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing green background aura -->
    <path
        android:pathData="M 54,18 A 36,36 0 1, 1 53.9, 18 Z"
        android:fillAlpha="0.08"
        android:fillColor="#00FF88" />

    <!-- Thin glowing neon-green concentric circular paths -->
    <path
        android:pathData="M 54,8 A 46,46 0 1, 1 53.9, 8 Z"
        android:strokeWidth="0.8"
        android:strokeColor="#2000FF88" />

    <path
        android:pathData="M 54,18 A 36,36 0 1, 1 53.9, 18 Z"
        android:strokeWidth="1.2"
        android:strokeColor="#3000FF88" strokeLineJoin="round" />

</vector>
