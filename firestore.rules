rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)).data.role == 'superadmin'
        ) && 
        get(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)).data.active != false;
    }

    function isRider() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/ek_delivery_persons/$(request.auth.uid));
    }

    function isRiderUpdate(currentData, nextData) {
      return currentData.id == nextData.id &&
             currentData.customerId == nextData.customerId &&
             currentData.customerPhone == nextData.customerPhone &&
             currentData.customerName == nextData.customerName &&
             currentData.deliveryAddress == nextData.deliveryAddress &&
             currentData.subtotalAmount == nextData.subtotalAmount &&
             currentData.totalAmount == nextData.totalAmount &&
             currentData.items == nextData.items &&
             currentData.createdAt == nextData.createdAt &&
             currentData.deliveryFee == nextData.deliveryFee &&
             currentData.couponDiscount == nextData.couponDiscount &&
             currentData.appliedCouponCode == nextData.appliedCouponCode &&
             currentData.loyaltyDiscount == nextData.loyaltyDiscount &&
             (nextData.assignedExecutiveId == request.auth.uid || nextData.deliveryExecutiveId == request.auth.uid) &&
             (
               // Transition A: Claiming (status ready remains, executive fields set)
               (currentData.status == 'ready' && nextData.status == 'ready' && currentData.assignedExecutiveId == null && nextData.assignedExecutiveId == request.auth.uid) ||
               // Transition B: Ready -> Delivering (rider moves order to active delivery)
               (currentData.status == 'ready' && nextData.status == 'delivering' && currentData.assignedExecutiveId == request.auth.uid) ||
               // Transition C: Delivering -> Delivered (rider completes delivery)
               (currentData.status == 'delivering' && nextData.status == 'delivered' && currentData.assignedExecutiveId == request.auth.uid)
             );
    }

    // Orders: customers can create and read own, admin can do everything, riders can claim and update
    match /ek_orders/{orderId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          resource.data.customerId == request.auth.uid || 
          resource.data.assignedExecutiveId == request.auth.uid ||
          resource.data.deliveryExecutiveId == request.auth.uid
        )
      );
      
      allow create: if isAdmin() || (
        isAuthenticated() && (
          request.resource.data.userId == request.auth.uid || 
          request.resource.data.customerId == request.auth.uid
        )
      );
      
      allow update: if isAdmin() || (
        isAuthenticated() && (
          // Customer Cancellation
          (
            (resource.data.userId == request.auth.uid || resource.data.customerId == request.auth.uid) &&
            resource.data.status in ['PENDING', 'pending', 'PLACED', 'placed', 'NEW', 'new', 'READY_FOR_ACCEPTANCE', 'ready_for_acceptance'] &&
            request.resource.data.status in ['CANCELLED', 'cancelled'] &&
            request.resource.data.cancelledBy == 'customer' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledBy', 'cancelledAt', 'updatedAt'])
          ) ||
          // Rider status updates
          (
            isRider() && isRiderUpdate(resource.data, request.resource.data)
          )
        )
      );
      
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin();
      allow delete: if false;
    }

    // Users: only the owner can read/write their own doc, admin has full access
    match /ek_users/{userId} {
      allow get: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Products: anyone can read, only admin writes
    match /ek_products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories: anyone can read, only admin writes
    match /ek_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons: anyone can read, only admin writes
    match /ek_coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Delivery Zones: anyone can read, only admin writes
    match /ek_delivery_zones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners: anyone can read, only admin writes
    match /ek_banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews: anyone can read, creator or admin can write
    match /ek_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.customerId == request.auth.uid
      );
      allow update, delete: if isAdmin() || (
        isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          resource.data.customerId == request.auth.uid
        )
      );
    }

    // FCM queue: authenticated write only, admin can manage
    match /ek_fcm_queue/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Admin accounts: only self or admin read, only admin write
    match /ek_admin_accounts/{docId} {
      allow get: if isAuthenticated() && (request.auth.uid == docId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Delivery persons: admin has full writes, rider can update operational status/location fields
    match /ek_delivery_persons/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == docId);
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.auth.uid == docId && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'currentLocation', 'latitude', 'longitude', 'availability', 'onlineStatus', 'lastUpdated', 'updatedAt', 'password', 'fcmToken'
        ])
      );
      allow delete: if isAdmin();
    }

    // Settings: anyone can read, only admin writes
    match /ek_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tombstones: write allowed only for administrators
    match /ek_tombstones/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Meta: allow anyone to read, only admin writes
    match /ek_meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
