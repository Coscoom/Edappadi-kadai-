rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Orders: customers can create, admin/delivery can read+update
    match /ek_orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /orders/{orderId} {
      allow create, read, update, delete: if request.auth != null;
    }

    // Users: only the owner can read/write their own doc
    match /ek_users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Products: anyone can read, only admin writes (authenticated)
    match /ek_products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Categories: anyone can read, authenticated write
    match /ek_categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Coupons: anyone can read, authenticated write
    match /ek_coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Delivery Zones: anyone can read, authenticated write
    match /ek_delivery_zones/{zoneId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Banners: anyone can read, authenticated write
    match /ek_banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reviews: anyone can read, authenticated write
    match /ek_reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // FCM queue: authenticated write only
    match /ek_fcm_queue/{docId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // Admin accounts: authenticated only
    match /ek_admin_accounts/{docId} {
      allow read, write: if request.auth != null;
    }

    // Delivery persons: authenticated only
    match /ek_delivery_persons/{docId} {
      allow read, write: if request.auth != null;
    }

    // Settings: anyone can read, authenticated write
    match /ek_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tombstones: allow anyone to read, authenticated write
    match /ek_tombstones/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Meta: allow anyone to read, authenticated write
    match /ek_meta/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
