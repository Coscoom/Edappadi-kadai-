rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)).data.get('role', 'admin') == 'admin' || 
          get(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)).data.get('role', 'admin') == 'superadmin'
        ) && 
        get(/databases/$(database)/documents/ek_admin_accounts/$(request.auth.uid)).data.get('active', true) != false;
    }

    function isRider() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/ek_delivery_persons/$(request.auth.uid));
    }

    function isRiderUpdate(currentData, nextData) {
      return currentData.id == nextData.id &&
             (currentData.customerId == nextData.customerId || currentData.userId == nextData.userId) &&
             currentData.customerPhone == nextData.customerPhone &&
             currentData.customerName == nextData.customerName &&
             currentData.deliveryAddress == nextData.deliveryAddress &&
             currentData.subtotalAmount == nextData.subtotalAmount &&
             currentData.totalAmount == nextData.totalAmount &&
             currentData.items == nextData.items &&
             currentData.createdAt == nextData.createdAt &&
             (
               nextData.get('riderUid', '') == request.auth.uid || 
               nextData.get('assignedExecutiveId', '') == request.auth.uid || 
               nextData.get('deliveryExecutiveId', '') == request.auth.uid ||
               nextData.get('assignedDeliveryPartnerUid', '') == request.auth.uid ||
               nextData.get('riderId', '') == request.auth.uid ||
               nextData.get('deliveryPartnerUid', '') == request.auth.uid
             ) &&
             (
               currentData.get('riderUid', '') == request.auth.uid || 
               currentData.get('assignedExecutiveId', '') == request.auth.uid || 
               currentData.get('deliveryExecutiveId', '') == request.auth.uid ||
               currentData.get('assignedDeliveryPartnerUid', '') == request.auth.uid ||
               currentData.get('riderId', '') == request.auth.uid ||
               currentData.get('deliveryPartnerUid', '') == request.auth.uid
             ) && (
               // Transition A: Ready -> Delivering / OUT_FOR_DELIVERY
               ((currentData.status == 'ready' || currentData.status == 'ACCEPTED' || currentData.status == 'pending') && (nextData.status == 'delivering' || nextData.status == 'OUT_FOR_DELIVERY' || nextData.status == 'ready')) ||
               // Transition B: Delivering -> Delivered
               ((currentData.status == 'delivering' || currentData.status == 'OUT_FOR_DELIVERY') && (nextData.status == 'delivered' || nextData.status == 'DELIVERED')) ||
               // Transition C: Location/Progress update (status remains unchanged)
               (currentData.status == nextData.status)
             );
    }

    // Orders: customers can create and read own, admin can do everything, riders can claim and update
    match /ek_orders/{orderId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          resource.data.customerId == request.auth.uid || 
          resource.data.get('riderUid', '') == request.auth.uid ||
          resource.data.get('assignedExecutiveId', '') == request.auth.uid ||
          resource.data.get('deliveryExecutiveId', '') == request.auth.uid ||
          resource.data.get('assignedDeliveryPartnerUid', '') == request.auth.uid ||
          resource.data.get('riderId', '') == request.auth.uid ||
          resource.data.get('deliveryPartnerUid', '') == request.auth.uid
        )
      );
      
      allow create: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.userId == request.auth.uid && 
        request.resource.data.customerId == request.auth.uid
      );
      
      allow update: if isAdmin() || (
        isAuthenticated() && (
          // Customer Cancellation
          (
            (resource.data.userId == request.auth.uid || resource.data.customerId == request.auth.uid) &&
            resource.data.status in ['PENDING', 'pending', 'PLACED', 'placed', 'NEW', 'new', 'READY_FOR_ACCEPTANCE', 'ready_for_acceptance'] &&
            request.resource.data.status in ['CANCELLED', 'cancelled'] &&
            request.resource.data.cancelledBy == 'customer' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledBy', 'cancelledAt', 'updatedAt'])
          ) ||
          // Rider status updates
          (
            isRider() && isRiderUpdate(resource.data, request.resource.data)
          )
        )
      );
      
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin();
      allow delete: if false;
    }

    // Users: only the owner can read/write their own doc, admin has full access
    match /ek_users/{userId} {
      allow get: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Legacy/Simplification users collection
    match /users/{userId} {
      allow get: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Legacy/Simplification settings collection
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products: anyone can read, only admin writes
    match /ek_products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories: anyone can read, only admin writes
    match /ek_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons: anyone can read, only admin writes
    match /ek_coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Delivery Zones: anyone can read, only admin writes
    match /ek_delivery_zones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners: anyone can read, only admin writes
    match /ek_banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews: anyone can read, creator or admin can write
    match /ek_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.customerId == request.auth.uid
      );
      allow update, delete: if isAdmin() || (
        isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          resource.data.customerId == request.auth.uid
        )
      );
    }

    // FCM queue: authenticated write only, admin can manage
    match /ek_fcm_queue/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Admin accounts: only self or admin read, only admin write, but allow authenticated users to read active approved admins
    match /ek_admin_accounts/{docId} {
      allow get: if isAuthenticated() && (request.auth.uid == docId || isAdmin() || resource.data.active != false);
      allow list: if isAuthenticated() && (isAdmin() || (resource.data.active != false && request.query.limit <= 20));
      allow create, update, delete: if isAdmin();
    }

    // Delivery persons: admin has full writes, rider can update operational status/location fields, but allow authenticated users to read active approved riders
    match /ek_delivery_persons/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == docId || (resource.data.isActive != false && request.query.limit <= 20)));
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == docId);
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.auth.uid == docId && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'currentLocation', 'latitude', 'longitude', 'availability', 'onlineStatus', 'lastUpdated', 'updatedAt', 'password', 'fcmToken'
        ])
      );
      allow delete: if isAdmin();
    }

    // Settings: anyone can read, only admin writes
    match /ek_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Secrets: deny all client read/write
    match /ek_secrets/{docId} {
      allow read, write: if false;
    }

    // Tombstones: write allowed only for administrators
    match /ek_tombstones/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Meta: allow anyone to read, only admin writes
    match /ek_meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
